# Copy to .env (or export) to configure the runtime.

# --- Backend selection ---------------------------------------------------
# 1 = in-process mock (default; no hardware). 0 = real vLLM over HTTP.
MA_USE_MOCK=1

# --- Real vLLM endpoints (used only when MA_USE_MOCK=0) -------------------
MA_SMALL_URL=http://localhost:8001
MA_LARGE_URL=http://localhost:8002
MA_SMALL_MODEL=meta-llama/Llama-3.1-8B-Instruct
MA_LARGE_MODEL=meta-llama/Llama-3.1-70B-Instruct

# --- Generation params ---------------------------------------------------
MA_TEMPERATURE=0.0
MA_MAX_TOKENS=1536
MA_TIMEOUT_S=120
MA_MAX_RETRIES=3
MA_MAX_REVISIONS=2

# HF token for gated meta-llama weights (real mode only)
# HF_TOKEN=hf_xxx

# --- Structured output / robustness (real mode) --------------------------
MA_GUIDED_JSON=1            # constrain vLLM output to each agent's JSON schema
MA_GUIDED_BACKEND=          # xgrammar | outlines | lm-format-enforcer (optional)
MA_PARSE_RETRIES=2          # retry agent call on invalid/malformed JSON
